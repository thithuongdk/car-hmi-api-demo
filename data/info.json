{
    "section_id": 123,
    "project": {
        "name": "CarPC HMI System",
        "version": "1.2.0",
        "environment": "development"
    },
    "hardware": {
        "can_bus": {
            "can0": {
                "bitrate": 500000,
                "retry_limit": 3,
                "rate_limit_ms": 100,
                "dbc_file": [
                    "/opt/carpc/assets/vehicle1.dbc",
                    "/opt/carpc/assets/vehicle2.dbc"
                ]
            },
            "can1": {
                "bitrate": 500000,
                "retry_limit": 3,
                "rate_limit_ms": 100,
                "dbc_file": [
                    "/opt/carpc/assets/vehicle3.dbc",
                    "/opt/carpc/assets/vehicle4.dbc"
                ]
            }
        }
    },
    "server": {
        "host": "0.0.0.0",
        "port": 8000,
        "cors_origins": [
            "http://localhost:3000",
            "https://carpc-demo.onrender.com"
        ],
        "websocket": {
            "endpoint": "/ws/signals",
            "broadcast_interval_ms": 100
        }
    },
    "storage": {
        "db_path": "/opt/carpc/data/trips.db",
        "log_level": "DEBUG",
        "retention_days": 30
    },
    "video": {
        "dms_camera": {
            "source": "rtsp://127.0.0.1:8554/dms",
            "resolution": "640x480",
            "fps": 30,
            "pipeline": "rtspsrc location={} ! rtph264depay ! h264parse ! avdec_h264 ! videoconvert ! appsink"
        }
    },
    "safety": {
        "speed_limit_max": 200,
        "temp_threshold_critical": 105,
        "write_access_enabled": true
    },
