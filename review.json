        "payload_example": {
            "timestamp": "2024-06-01T12:00:00Z",
            "signals": [ 
                {
                    "name": "EngineSpeed",
                    "value": 3000
                },
                {
                    "name": "CoolantTemp",
                    "value": 90
                }
            ]
        }
    },
