{
    "_readme": "API contract spec - each key maps to one API group. payload_example shows real request/response shapes.",
    "info": {
        "description": "Read-only project & hardware metadata. api_key is always redacted.",
        "api": true,
        "endpoint": "GET /api/info",
        "available_mode": [
            "user",
            "dev"
        ],
        "method": [
            "GET"
        ],
        "response_example": {
            "section_id": 123,
            "project": {
                "name": "CarPC HMI System",
                "version": "1.2.0",
                "environment": "development"
            },
            "hardware": {
                "can_bus": {
                    "can0": {
                        "bitrate": 500000,
                        "retry_limit": 3,
                        "rate_limit_ms": 100,
                        "dbc_file": [
                            "/opt/carpc/assets/vehicle1.dbc"
                        ]
                    }
                }
            },
            "server": {
                "host": "0.0.0.0",
                "port": 8000,
                "cors_origins": [
                    "http://localhost:3000"
                ],
                "websocket": {
                    "endpoint": "/ws/signals",
                    "broadcast_interval_ms": 100
                }
            },
            "storage": {
                "db_path": "/opt/carpc/data/trips.db",
                "log_level": "DEBUG",
                "retention_days": 30
            },
            "safety": {
                "speed_limit_max": 200,
                "temp_threshold_critical": 105,
                "write_access_enabled": true
            },
            "video": {
                "dms_camera": {
                    "source": "rtsp://127.0.0.1:8554/dms",
                    "resolution": "640x480",
                    "fps": 30
                }
            },
            "profiles": [
                {
                    "profile_name": "U0",
                    "description": "Front seat profile",
                    "signals": [
                        "ABL_FL_RetractRequest",
                        "..."
                    ]
                }
            ]
        }
    },
    "profiles": {
        "description": "List all profiles with their signal lists.",
        "api": true,
        "endpoint": "GET /api/profiles",
        "available_mode": [
            "dev",
            "user"
        ],
        "method": [
            "GET"
        ],
        "response_example": {
            "section_id": 123,
            "profiles": [
                {
                    "profile_name": "U0",
                    "description": "Front seat profile",
                    "signals": [
                        "ABL_FL_RetractRequest",
                        "ABL_FR_RetractRequest",
                        "..."
                    ],
                    "selected": true
                },
                {
                    "profile_name": "U1",
                    "description": "Rear seat profile",
                    "signals": [
                        "ABL_R1_RetractRequest",
                        "..."
                    ],
                    "selected": false
                }
            ]
        }
    },
    "profile_get": {
        "description": "Get one profile by name (or active profile if name omitted).",
        "api": true,
        "endpoint": "GET /api/profile?name=U0",
        "available_mode": [
            "user",
            "dev"
        ],
        "method": [
            "GET"
        ],
        "response_example": {
            "section_id": 123,
            "profile_name": "U0",
            "description": "Front seat profile",
            "signals": [
                "ABL_FL_RetractRequest",
                "ABL_FR_RetractRequest",
                "ACR_FL_RetractRequest",
                "ACR_FR_RetractRequest"
            ],
            "selected": true
        }
    },
    "profile_create": {
        "description": "Create a new profile. Name must be unique.",
        "api": true,
        "endpoint": "POST /api/profile",
        "available_mode": [
            "dev"
        ],
        "method": [
            "POST"
        ],
        "request_body": {
            "profile_name": "Custom1",
            "description": "My custom profile",
            "signals": [
                "HB_FL_ActivationLevel",
                "ISB_FL_ColorGreen"
            ]
        },
        "response_example": {
            "section_id": 124,
            "profile_name": "Custom1",
            "description": "My custom profile",
            "signals": [
                "HB_FL_ActivationLevel",
                "ISB_FL_ColorGreen"
            ],
            "selected": false
        },
        "errors": [
            {
                "http": 409,
                "code": 3005,
                "id": "VAL_CONFLICT",
                "reason": "Profile name already exists"
            }
        ]
    },
    "profile_update": {
        "description": "Update existing profile. section_id must match current value.",
        "api": true,
        "endpoint": "PUT /api/profile",
        "available_mode": [
            "dev"
        ],
        "method": [
            "PUT"
        ],
        "request_body": {
            "section_id": 124,
            "profile_name": "U0",
            "description": "Updated front seat",
            "signals": [
                "ABL_FL_RetractRequest",
                "HB_FL_ActivationLevel"
            ]
        },
        "response_example": {
            "section_id": 125,
            "profile_name": "U0",
            "description": "Updated front seat",
            "signals": [
                "ABL_FL_RetractRequest",
                "HB_FL_ActivationLevel"
            ],
            "selected": true
        },
        "errors": [
            {
                "http": 404,
                "code": 3004,
                "id": "VAL_NOT_FOUND",
                "reason": "Profile not found"
            },
            {
                "http": 409,
                "code": 3005,
                "id": "VAL_CONFLICT",
                "reason": "section_id mismatch - stale update"
            }
        ]
    },
    "profile_delete": {
        "description": "Delete a profile by name.",
        "api": true,
        "endpoint": "DELETE /api/profile/{name}",
        "available_mode": [
            "dev"
        ],
        "method": [
            "DELETE"
        ],
        "response_example": {
            "deleted": "U0"
        },
        "errors": [
            {
                "http": 404,
                "code": 3004,
                "id": "VAL_NOT_FOUND",
                "reason": "Profile not found"
            }
        ]
    },
    "configs": {
        "description": "Read full system info from info.json. Read-only. Includes project, hardware, server, storage, video, safety and profiles.",
        "api": true,
        "endpoint": "GET /configs",
        "available_mode": [
            "dev"
        ],
        "method": [
            "GET"
        ],
        "note": "Source: data/info.json - read-only, not editable via API. Use GET/PUT /config for editable settings.",
        "response_example": {
            "section_id": 123,
            "project": {
                "name": "CarPC HMI System",
                "version": "1.2.0",
                "environment": "development"
            },
            "hardware": {
                "can_bus": {
                    "can0": {
                        "bitrate": 500000,
                        "retry_limit": 3,
                        "rate_limit_ms": 100,
                        "dbc_file": ["/opt/carpc/assets/vehicle1.dbc"]
                    }
                }
            },
            "server": {
                "host": "0.0.0.0",
                "port": 8000,
                "cors_origins": ["http://localhost:3000"],
                "websocket": {
                    "endpoint": "/ws/signals",
                    "broadcast_interval_ms": 100
                }
            },
            "storage": {
                "db_path": "/opt/carpc/data/trips.db",
                "log_level": "DEBUG",
                "retention_days": 30
            },
            "safety": {
                "speed_limit_max": 200,
                "temp_threshold_critical": 105,
                "write_access_enabled": true
            },
            "video": {
                "dms_camera": {
                    "source": "rtsp://127.0.0.1:8554/dms",
                    "resolution": "640x480",
                    "fps": 30,
                    "pipeline": "rtspsrc location={} ! rtph264depay ! h264parse ! avdec_h264 ! videoconvert ! appsink"
                }
            },
            "profiles": [
                {
                    "profile_name": "U0",
                    "description": "Front seat profile",
                    "signals": ["ABL_FL_RetractRequest", "..."]
                }
            ]
        }
    },
    "config_get": {
        "description": "Get current editable system configuration from config.json (hardware CAN bus, storage, safety settings).",
        "api": true,
        "endpoint": "GET /config",
        "available_mode": [
            "dev"
        ],
        "method": [
            "GET"
        ],
        "note": "Source: data/config.json - contains hardware.can_bus, storage, safety. These fields can be updated via PUT /config.",
        "response_example": {
            "section_id": 123,
            "hardware": {
                "can_bus": {
                    "can0": {
                        "bitrate": 500000,
                        "retry_limit": 3,
                        "rate_limit_ms": 100,
                        "dbc_file": ["/opt/carpc/assets/vehicle1.dbc", "/opt/carpc/assets/vehicle2.dbc"]
                    },
                    "can1": {
                        "bitrate": 500000,
                        "retry_limit": 3,
                        "rate_limit_ms": 100,
                        "dbc_file": ["/opt/carpc/assets/vehicle3.dbc", "/opt/carpc/assets/vehicle4.dbc"]
                    }
                }
            },
            "storage": {
                "log_level": "DEBUG",
                "retention_days": 30
            },
            "safety": {
                "speed_limit_max": 200,
                "temp_threshold_critical": 105,
                "write_access_enabled": true
            }
        }
    },
    "config_update": {
        "description": "Update editable config fields in config.json (hardware.can_bus, storage, safety). section_id must match current value.",
        "api": true,
        "endpoint": "PUT /config",
        "available_mode": [
            "dev"
        ],
        "method": [
            "PUT"
        ],
        "note": "Only fields present in config.json are writable. Partial update supported - omitted fields are unchanged.",
        "request_body": {
            "section_id": 123,
            "hardware": {
                "can_bus": {
                    "can0": {
                        "bitrate": 250000,
                        "retry_limit": 5
                    }
                }
            },
            "storage": {
                "log_level": "INFO",
                "retention_days": 60
            },
            "safety": {
                "write_access_enabled": false
            }
        },
        "response_example": {
            "section_id": 124,
            "hardware": {
                "can_bus": {
                    "can0": {
                        "bitrate": 250000,
                        "retry_limit": 5,
                        "rate_limit_ms": 100,
                        "dbc_file": ["/opt/carpc/assets/vehicle1.dbc", "/opt/carpc/assets/vehicle2.dbc"]
                    },
                    "can1": {
                        "bitrate": 500000,
                        "retry_limit": 3,
                        "rate_limit_ms": 100,
                        "dbc_file": ["/opt/carpc/assets/vehicle3.dbc", "/opt/carpc/assets/vehicle4.dbc"]
                    }
                }
            },
            "storage": {
                "log_level": "INFO",
                "retention_days": 60
            },
            "safety": {
                "speed_limit_max": 200,
                "temp_threshold_critical": 105,
                "write_access_enabled": false
            }
        },
        "errors": [
            {
                "http": 409,
                "code": 3005,
                "id": "VAL_CONFLICT",
                "reason": "section_id mismatch - stale update"
            },
            {
                "http": 400,
                "code": 3002,
                "id": "VAL_MISSING_FIELD",
                "reason": "section_id not provided"
            }
        ]
    },
    "signals": {
        "description": "Snapshot of current signal values filtered by active profile.",
        "api": true,
        "endpoint": "GET /signals",
        "available_mode": [
            "user",
            "dev"
        ],
        "method": [
            "GET"
        ],
        "response_example": {
            "timestamp": "2026-04-01T10:00:00.000Z",
            "signals": [
                {
                    "name": "HB_DynamicTargetTemp",
                    "value": 37
                },
                {
                    "name": "HMI_CrashSeverity",
                    "value": 0
                }
            ]
        }
    },
    "signals_available": {
        "description": "Full signal metadata + current values for all signals in active profile.",
        "api": true,
        "endpoint": "GET /signals/available",
        "available_mode": [
            "user",
            "dev"
        ],
        "method": [
            "GET"
        ],
        "note": "TX=true signals are writable by HMI. TX=false are read-only sensors.",
        "response_example": {
            "signals": [
                {
                    "name": "HMI_CrashSeverity",
                    "value": 0,
                    "unit": "",
                    "min": 0,
                    "max": 7,
                    "description": "Crash Severity Selection from HMI",
                    "states": [],
                    "TX": true,
                    "RX": true,
                    "source": [
                        "CAR_PC"
                    ],
                    "destination": [
                        "PANTHER"
                    ]
                },
                {
                    "name": "HB_FL_ActivationLevel",
                    "value": 2,
                    "unit": "",
                    "min": 0,
                    "max": 7,
                    "description": "Activation Level for HB requested by HMI",
                    "states": [
                        {
                            "value": 1,
                            "description": "Level 1"
                        },
                        {
                            "value": 2,
                            "description": "Level 2"
                        }
                    ],
                    "TX": true,
                    "RX": true,
                    "source": [
                        "CAR_PC"
                    ],
                    "destination": [
                        "PANTHER"
                    ]
                },
                {
                    "name": "HB_DynamicTargetTemp",
                    "value": 37,
                    "unit": "deg C",
                    "min": 0,
                    "max": 40,
                    "description": "Dynamic target temperature",
                    "states": [],
                    "TX": false,
                    "RX": true,
                    "source": [
                        "PANTHER"
                    ],
                    "destination": [
                        "CAR_PC"
                    ]
                }
            ]
        }
    },
    "signal_write": {
        "description": "Write a single writable signal (TX=true). Rejected if TX=false.",
        "api": true,
        "endpoint": "PUT /signals/{signal_name}",
        "available_mode": [
            "user",
            "dev"
        ],
        "method": [
            "PUT"
        ],
        "request_body": {
            "value": 3
        },
        "response_example": {
            "name": "HB_FL_ActivationLevel",
            "value": 3,
            "timestamp": "2026-04-01T10:00:00.000Z"
        },
        "errors": [
            {
                "http": 404,
                "code": 3004,
                "id": "VAL_NOT_FOUND",
                "reason": "Signal not found"
            },
            {
                "http": 403,
                "code": 4002,
                "id": "SAFE_WRITE_DENIED",
                "reason": "Signal TX=false, not writable"
            },
            {
                "http": 422,
                "code": 3003,
                "id": "VAL_OUT_OF_RANGE",
                "reason": "Value outside min/max"
            }
        ]
    },
    "signal_batch_write": {
        "description": "Write multiple writable signals in one call. Each result reports individual status.",
        "api": true,
        "endpoint": "POST /signals/batch_update",
        "available_mode": [
            "user",
            "dev"
        ],
        "method": [
            "POST"
        ],
        "request_body": {
            "signals": [
                {
                    "name": "HB_FL_ActivationLevel",
                    "value": 3
                },
                {
                    "name": "HMI_CrashSeverity",
                    "value": 1
                },
                {
                    "name": "HB_DynamicTargetTemp",
                    "value": 5
                }
            ]
        },
        "response_example": {
            "results": [
                {
                    "name": "HB_FL_ActivationLevel",
                    "status": "ok",
                    "value": 3
                },
                {
                    "name": "HMI_CrashSeverity",
                    "status": "ok",
                    "value": 1
                },
                {
                    "name": "HB_DynamicTargetTemp",
                    "status": "not_writable"
                }
            ]
        },
        "result_status_values": [
            "ok",
            "not_writable",
            "not_found",
            "out_of_range"
        ]
    },
    "websocket": {
        "description": "Realtime signal stream. Broadcasts active-profile signals every broadcast_interval_ms.",
        "api": true,
        "endpoint": "wss://{host}/ws/signals",
        "available_mode": [
            "user",
            "dev"
        ],
        "protocol": "WebSocket",
        "connection_note": "Connect without extra headers. Server broadcasts automatically after connection.",
        "message_example": {
            "timestamp": "2026-04-01T10:00:00.000Z",
            "signals": [
                {
                    "name": "HB_DynamicTargetTemp",
                    "value": 38
                },
                {
                    "name": "HB_FL_ActivationLevel",
                    "value": 2
                }
            ]
        },
        "close_codes": {
            "1000": "Normal close",
            "1006": "Abnormal close - retry with exponential backoff",
            "1008": "Policy violation (bad token)",
            "1011": "Server error"
        }
    },
    "error_codes": {
        "description": "App-level error taxonomy. Every error response includes { error, code, id }.",
        "error_response_shape": {
            "error": "Human-readable message",
            "code": 4002,
            "id": "SAFE_WRITE_DENIED"
        },
        "groups": {
            "10xx_system": [
                {
                    "code": 1000,
                    "id": "SYS_UNKNOWN",
                    "http": 500,
                    "description": "Unhandled server error"
                },
                {
                    "code": 1001,
                    "id": "SYS_DB_LOCKED",
                    "http": 503,
                    "description": "SQLite database locked"
                },
                {
                    "code": 1002,
                    "id": "SYS_MAINTENANCE",
                    "http": 503,
                    "description": "System under maintenance"
                }
            ],
            "20xx_hardware": [
                {
                    "code": 2001,
                    "id": "HW_CAN_0_ERROR",
                    "http": 503,
                    "description": "CAN0 bus communication timeout"
                },
                {
                    "code": 2002,
                    "id": "HW_CAN_1_ERROR",
                    "http": 504,
                    "description": "CAN1 bus communication timeout"
                },
                {
                    "code": 2003,
                    "id": "HW_CAM_LOST",
                    "http": 503,
                    "description": "Camera signal lost"
                }
            ],
            "30xx_validation": [
                {
                    "code": 3001,
                    "id": "VAL_INVALID_JSON",
                    "http": 400,
                    "description": "Malformed JSON body"
                },
                {
                    "code": 3002,
                    "id": "VAL_MISSING_FIELD",
                    "http": 400,
                    "description": "Required field missing"
                },
                {
                    "code": 3003,
                    "id": "VAL_OUT_OF_RANGE",
                    "http": 422,
                    "description": "Value outside min/max"
                },
                {
                    "code": 3004,
                    "id": "VAL_NOT_FOUND",
                    "http": 404,
                    "description": "Resource not found"
                },
                {
                    "code": 3005,
                    "id": "VAL_CONFLICT",
                    "http": 409,
                    "description": "section_id mismatch or name conflict"
                }
            ],
            "40xx_safety_security": [
                {
                    "code": 4001,
                    "id": "SEC_UNAUTHORIZED",
                    "http": 401,
                    "description": "Invalid or missing API key"
                },
                {
                    "code": 4002,
                    "id": "SAFE_WRITE_DENIED",
                    "http": 403,
                    "description": "Write denied - TX=false or vehicle moving"
                },
                {
                    "code": 4003,
                    "id": "SAFE_WATCHDOG_TRIP",
                    "http": 500,
                    "description": "Watchdog detected hang"
                },
                {
                    "code": 4004,
                    "id": "SAFE_VEHICLE_MOVING",
                    "http": 403,
                    "description": "Operation not allowed while vehicle is moving"
                }
            ]
        }
    }
}